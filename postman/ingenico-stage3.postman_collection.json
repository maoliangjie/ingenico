{
  "info": {
    "name": "Ingenico Stage 3",
    "_postman_id": "7f91c57b-4282-4a33-a1b4-ingenico-stage3",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Chat",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"What is the current health status and how many documents are loaded?\"\n}"
        },
        "url": "{{base_url}}/chat"
      }
    },
    {
      "name": "Chat Stream",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "text/event-stream" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"How do I start a new conversation?\"\n}"
        },
        "url": "{{base_url}}/chat/stream"
      }
    },
    {
      "name": "List MCP Tools",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/mcp/tools"
      }
    },
    {
      "name": "Invoke Health Tool",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"arguments\": {}\n}"
        },
        "url": "{{base_url}}/mcp/tools/get_system_health"
      }
    },
    {
      "name": "Invoke Knowledge Search Tool",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"arguments\": {\n    \"query\": \"How do I start a new conversation?\",\n    \"top_k\": 3\n  }\n}"
        },
        "url": "{{base_url}}/mcp/tools/search_knowledge"
      }
    },
    {
      "name": "List Uploads",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/uploads"
      }
    },
    {
      "name": "Create Upload",
      "request": {
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": "{{base_url}}/upload"
      }
    },
    {
      "name": "Replace Upload",
      "request": {
        "method": "PUT",
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": "{{base_url}}/uploads/{{file_id}}"
      }
    },
    {
      "name": "PDF Upload Note",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health",
        "description": "Use Create Upload or Replace Upload with a text-based .pdf file. Image-only, encrypted, or unreadable PDFs should return 400."
      }
    },
    {
      "name": "Delete Upload",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/uploads/{{file_id}}"
      }
    }
  ]
}
